{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sirinx.co/schemas/agent-runtime/resource-cleanup-effect-attempt.v1.schema.json",
  "title": "ResourceCleanupEffectAttemptV1PlanOnly",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attemptId",
    "effectKey",
    "ticketId",
    "grantId",
    "taskId",
    "runId",
    "action",
    "circuit",
    "actionDigest",
    "admissionDigest",
    "executorPrincipalId",
    "state",
    "expectedVersion",
    "createdAt",
    "requestingAt",
    "startedAt",
    "processIdentity",
    "finishedAt",
    "exit",
    "postReceiptId",
    "retryCount",
    "automaticRetry",
    "attemptDigest",
    "status"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0-plan" },
    "attemptId": { "type": "string", "pattern": "^ATTEMPT-[A-Za-z0-9._-]+$" },
    "effectKey": { "type": "string", "pattern": "^resource_cleanup:[A-Za-z0-9._:-]+$", "maxLength": 256 },
    "ticketId": { "type": "string", "pattern": "^TKT-[A-Za-z0-9._-]+$" },
    "grantId": { "type": "string", "pattern": "^GRANT-[A-Za-z0-9._-]+$" },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Za-z0-9._-]+$" },
    "runId": { "type": "string", "pattern": "^RUN-[A-Za-z0-9._-]+$" },
    "action": { "const": "RESOURCE_CLEANUP" },
    "circuit": { "const": "resource_cleanup" },
    "actionDigest": { "$ref": "#/$defs/sha256" },
    "admissionDigest": { "$ref": "#/$defs/sha256" },
    "executorPrincipalId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "state": { "const": "PREPARED" },
    "expectedVersion": { "const": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "requestingAt": { "const": null },
    "startedAt": { "const": null },
    "processIdentity": { "const": null },
    "finishedAt": { "const": null },
    "exit": { "const": null },
    "postReceiptId": { "const": null },
    "retryCount": { "const": 0 },
    "automaticRetry": { "const": false },
    "attemptDigest": { "$ref": "#/$defs/sha256" },
    "status": { "const": "PLAN_ONLY_NO_DISPATCH" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
