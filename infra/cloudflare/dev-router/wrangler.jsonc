{
  "name": "sirinx-dev-router",
  "main": "./src/worker.js",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    {
      "pattern": "dev.sirinx.co/*",
      "zone_name": "sirinx.co",
      "custom_domain": true
    }
  ],
  "vars": {
    "DEV_API_HOST": "http://localhost:8790",
    "HERMES_API_HOST": "http://localhost:9000",
    "SIRINX_WEB_HOST": "http://localhost:8080"
  }
}
