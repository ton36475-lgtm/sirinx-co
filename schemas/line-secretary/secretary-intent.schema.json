{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "secretary-intent.schema.json",
  "title": "LINE Secretary Intent",
  "description": "L1 contract-only representation of a classified secretary intent. It carries only aliases, references, digests, codes, and bounded metadata; it never carries raw LINE recipient identifiers, credentials, secrets, tokens, or message bodies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "intentId",
    "intent",
    "confidence",
    "riskClass",
    "requiresConfirmation",
    "createdAt",
    "correlationId",
    "sourceEventId",
    "idempotencyKey",
    "actor",
    "recipient",
    "payloadDigest",
    "classification",
    "parameters",
    "risk",
    "confirmation",
    "lifecycle",
    "persistence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "intentId": {
      "type": "string",
      "format": "uuid"
    },
    "intent": {
      "type": "string",
      "enum": [
        "CREATE_TASK_DRAFT",
        "PREPARE_APPOINTMENT",
        "CREATE_LEAD",
        "DRAFT_REPLY",
        "REQUEST_APPROVAL",
        "SEND_LINE_MESSAGE",
        "GENERATE_BRIEFING",
        "UNKNOWN",
        "BLOCKED"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskClass": {
      "type": "string",
      "enum": ["AUTO_GREEN", "AUTO_AMBER", "HUMAN_RED"]
    },
    "requiresConfirmation": {
      "type": "boolean"
    },
    "confirmationPolicy": {
      "description": "Optional normalized policy detail. The binding gate is requiresConfirmation plus riskClass.",
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "REQUIRED_BEFORE_EXTERNAL_EFFECT",
        "EXACT_HUMAN_APPROVAL"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "sourceEventId": {
      "type": "string",
      "format": "uuid"
    },
    "idempotencyKey": {
      "$ref": "line-event.schema.json#/$defs/idempotencyKey"
    },
    "actor": {
      "$ref": "line-event.schema.json#/$defs/actorReference"
    },
    "recipient": {
      "$ref": "line-event.schema.json#/$defs/recipientReference"
    },
    "payloadDigest": {
      "$ref": "line-event.schema.json#/$defs/sha256Digest"
    },
    "classification": {
      "$ref": "#/$defs/classification"
    },
    "parameters": {
      "$ref": "#/$defs/intentParameters"
    },
    "risk": {
      "$ref": "line-event.schema.json#/$defs/riskAssessment"
    },
    "confirmation": {
      "$ref": "line-event.schema.json#/$defs/confirmation"
    },
    "lifecycle": {
      "$ref": "#/$defs/intentLifecycle"
    },
    "persistence": {
      "$ref": "line-event.schema.json#/$defs/persistence"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "requiresConfirmation": {
            "const": false
          }
        },
        "required": ["requiresConfirmation"]
      },
      "then": {
        "properties": {
          "confirmation": {
            "properties": {
              "required": {
                "const": false
              },
              "status": {
                "const": "NOT_REQUIRED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requiresConfirmation": {
            "const": true
          }
        },
        "required": ["requiresConfirmation"]
      },
      "then": {
        "properties": {
          "confirmation": {
            "properties": {
              "required": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "riskClass": {
            "const": "HUMAN_RED"
          }
        },
        "required": ["riskClass"]
      },
      "then": {
        "properties": {
          "requiresConfirmation": {
            "const": true
          },
          "confirmationPolicy": {
            "const": "EXACT_HUMAN_APPROVAL"
          },
          "risk": {
            "properties": {
              "decision": {
                "const": "CONFIRMATION_REQUIRED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk": {
            "properties": {
              "decision": {
                "const": "AUTO_ALLOWED"
              }
            },
            "required": ["decision"]
          }
        },
        "required": ["risk"]
      },
      "then": {
        "properties": {
          "confirmation": {
            "properties": {
              "required": {
                "const": false
              },
              "status": {
                "const": "NOT_REQUIRED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk": {
            "properties": {
              "decision": {
                "const": "CONFIRMATION_REQUIRED"
              }
            },
            "required": ["decision"]
          }
        },
        "required": ["risk"]
      },
      "then": {
        "properties": {
          "confirmation": {
            "properties": {
              "required": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "risk": {
            "properties": {
              "decision": {
                "const": "BLOCKED"
              }
            },
            "required": ["decision"]
          }
        },
        "required": ["risk"]
      },
      "then": {
        "properties": {
          "lifecycle": {
            "properties": {
              "status": {
                "const": "BLOCKED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "const": "PREPARE_APPOINTMENT"
          }
        },
        "required": ["intent"]
      },
      "then": {
        "properties": {
          "risk": {
            "properties": {
              "decision": {
                "const": "CONFIRMATION_REQUIRED"
              }
            }
          },
          "confirmation": {
            "properties": {
              "required": {
                "const": true
              }
            }
          },
          "lifecycle": {
            "properties": {
              "status": {
                "enum": [
                  "CLASSIFIED",
                  "DRAFTED",
                  "AWAITING_CONFIRMATION",
                  "APPROVED",
                  "REJECTED",
                  "FAILED",
                  "BLOCKED"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "const": "REQUEST_APPROVAL"
          }
        },
        "required": ["intent"]
      },
      "then": {
        "properties": {
          "risk": {
            "properties": {
              "decision": {
                "const": "CONFIRMATION_REQUIRED"
              }
            }
          },
          "confirmation": {
            "properties": {
              "required": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "const": "SEND_LINE_MESSAGE"
          }
        },
        "required": ["intent"]
      },
      "then": {
        "properties": {
          "risk": {
            "properties": {
              "tier": {
                "const": "D"
              },
              "externalEffect": {
                "const": true
              },
              "decision": {
                "const": "CONFIRMATION_REQUIRED"
              }
            }
          },
          "confirmation": {
            "properties": {
              "required": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "intent": {
            "const": "BLOCKED"
          }
        },
        "required": ["intent"]
      },
      "then": {
        "properties": {
          "risk": {
            "properties": {
              "tier": {
                "const": "X"
              },
              "decision": {
                "const": "BLOCKED"
              }
            }
          },
          "lifecycle": {
            "properties": {
              "status": {
                "const": "BLOCKED"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classifierAlias", "reasonCodes"],
      "properties": {
        "classifierAlias": {
          "$ref": "line-event.schema.json#/$defs/safeAlias"
        },
        "reasonCodes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "line-event.schema.json#/$defs/safeCode"
          }
        }
      }
    },
    "intentParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instructionDigest",
        "subjectAlias",
        "resourceRefs",
        "requestedFor",
        "timezoneCode",
        "priorityCode"
      ],
      "properties": {
        "instructionDigest": {
          "$ref": "line-event.schema.json#/$defs/sha256Digest"
        },
        "subjectAlias": {
          "oneOf": [
            {
              "$ref": "line-event.schema.json#/$defs/safeAlias"
            },
            {
              "type": "null"
            }
          ]
        },
        "resourceRefs": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "line-event.schema.json#/$defs/safeRecordReference"
          }
        },
        "requestedFor": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "timezoneCode": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[A-Za-z_]+/[A-Za-z_]+$"
            },
            {
              "type": "null"
            }
          ]
        },
        "priorityCode": {
          "type": "string",
          "enum": ["LOW", "NORMAL", "HIGH", "URGENT"]
        }
      }
    },
    "intentLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "revision", "updatedAt", "statusReasonCode"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "CLASSIFIED",
            "DRAFTED",
            "AWAITING_CONFIRMATION",
            "APPROVED",
            "REJECTED",
            "DISPATCHED",
            "COMPLETED",
            "FAILED",
            "BLOCKED"
          ]
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "statusReasonCode": {
          "oneOf": [
            {
              "$ref": "line-event.schema.json#/$defs/safeCode"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
