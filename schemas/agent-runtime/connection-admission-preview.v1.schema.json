{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sirinx.co/schemas/agent-runtime/connection-admission-preview.v1.schema.json",
  "title": "ConnectionAdmissionPreviewV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "mode",
    "connectionId",
    "evidenceId",
    "planDigest",
    "evidenceDigest",
    "observedAt",
    "expiresAt",
    "validation",
    "readOnly",
    "ioPerformed",
    "admitted",
    "enabled",
    "endpointVerified",
    "agentCardTrusted",
    "handshakeReady",
    "authenticationValidated",
    "capabilityAuthorityValidated",
    "canConnect",
    "canRunMcp",
    "canEmitA2a",
    "canSendMessages",
    "authorityValidated",
    "durableAdmission",
    "replayProtectionAvailable",
    "evidenceUniquenessValidated",
    "networkCalls",
    "processStarted",
    "environmentRead",
    "secretsRead",
    "databaseWrites",
    "externalWrites",
    "messagesSent",
    "routesRegistered",
    "commandExecuted",
    "blockers",
    "stopPoint"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "status": { "const": "EVIDENCE_VALIDATED_NOT_ADMITTED" },
    "mode": { "const": "local-pure-preview" },
    "connectionId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "evidenceId": { "type": "string", "pattern": "^CEV-[A-Za-z0-9._-]+$" },
    "planDigest": { "$ref": "#/$defs/sha256" },
    "evidenceDigest": { "$ref": "#/$defs/sha256" },
    "observedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planDigestConsistent",
        "evidenceDigestConsistent",
        "endpointBindingConsistent",
        "capabilityDigestConsistent",
        "candidateRuntimeBindingsConsistent",
        "candidateContextAuthorityValidated",
        "clockAuthorityValidated"
      ],
      "properties": {
        "planDigestConsistent": { "const": true },
        "evidenceDigestConsistent": { "const": true },
        "endpointBindingConsistent": { "const": true },
        "capabilityDigestConsistent": { "const": true },
        "candidateRuntimeBindingsConsistent": { "const": true },
        "candidateContextAuthorityValidated": { "const": false },
        "clockAuthorityValidated": { "const": false }
      }
    },
    "readOnly": { "const": true },
    "ioPerformed": { "const": false },
    "admitted": { "const": false },
    "enabled": { "const": false },
    "endpointVerified": { "const": false },
    "agentCardTrusted": { "const": false },
    "handshakeReady": { "const": false },
    "authenticationValidated": { "const": false },
    "capabilityAuthorityValidated": { "const": false },
    "canConnect": { "const": false },
    "canRunMcp": { "const": false },
    "canEmitA2a": { "const": false },
    "canSendMessages": { "const": false },
    "authorityValidated": { "const": false },
    "durableAdmission": { "const": false },
    "replayProtectionAvailable": { "const": false },
    "evidenceUniquenessValidated": { "const": false },
    "networkCalls": { "const": false },
    "processStarted": { "const": false },
    "environmentRead": { "const": false },
    "secretsRead": { "const": false },
    "databaseWrites": { "const": false },
    "externalWrites": { "const": false },
    "messagesSent": { "const": false },
    "routesRegistered": { "const": false },
    "commandExecuted": { "const": false },
    "blockers": {
      "const": [
        "candidate_context_is_caller_supplied",
        "clock_authority_not_attested",
        "connection_authority_unavailable",
        "dns_resolution_and_origin_auth_unverified",
        "durable_connection_admission_unavailable",
        "effect_circuits_unavailable",
        "network_and_message_io_disabled",
        "replay_ledger_unavailable"
      ]
    },
    "stopPoint": {
      "const": "CONNECTION EVIDENCE VALIDATED - NO CONNECTION, MCP, A2A, OR MESSAGE AUTHORITY"
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
