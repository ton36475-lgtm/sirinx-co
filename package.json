{
  "name": "sirinx-co",
  "version": "0.2.0-pr-mono-002",
  "private": true,
  "description": "Canonical SIRINX OS monorepo governance scaffold with AdaptiveSync, PC node, Telegram dry-run control, and public-web source recovery.",
  "scripts": {
    "check": "node --check scripts/verify-pr-mono-001.mjs && node --check scripts/adaptive-sync-plan.mjs && node --check scripts/telegram-notify-preview.mjs && node --check scripts/windows-drive-d-handoff.mjs && node --check scripts/verify-next-phase.mjs && node --check services/telegram-command-bot/src/index.mjs && node scripts/verify-pr-mono-001.mjs && node scripts/verify-next-phase.mjs",
    "verify:mono-001": "node scripts/verify-pr-mono-001.mjs",
    "verify:next-phase": "node scripts/verify-next-phase.mjs",
    "pipeline:audit": "node scripts/pipeline-audit.mjs",
    "sync:plan": "node scripts/adaptive-sync-plan.mjs",
    "sync:handoff": "node scripts/windows-drive-d-handoff.mjs",
    "telegram:preview": "node scripts/telegram-notify-preview.mjs --dry-run",
    "telegram:bot:dry-run": "node services/telegram-command-bot/src/index.mjs --dry-run",
    "restore:public-web": "node scripts/restore-public-web-from-sirinx.mjs",
    "verify:public-web-import": "node scripts/verify-public-web-import.mjs",
    "web:check": "pnpm --config.verify-deps-before-run=false --dir apps/public-web check",
    "web:test": "pnpm --config.verify-deps-before-run=false --dir apps/public-web test",
    "web:build": "pnpm --config.verify-deps-before-run=false --dir apps/public-web build",
    "control:test": "vitest run services/dev-control-api/src --exclude services/dev-control-api/src/hermes-spec-first-swarm.test.mjs",
    "rust:build": "cargo build --workspace",
    "rust:test": "cargo test --workspace",
    "rust:serve": "cargo run -p sirinx-web"
  },
  "keywords": [
    "sirinx",
    "monorepo",
    "governance",
    "cloudflare-access",
    "millerdev",
    "public-web",
    "source-recovery",
    "ghostclaw"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
