# SIRINX OS canonical monorepo placeholders only.
# Do not put real secrets in this file.

SIRINX_ENV=local
PUBLIC_SITE_CANONICAL_HOST=www.sirinx.co
PRIVATE_HQ_HOST=dev.sirinx.co

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_NAME=office-brain

DEV_CONTROL_API_TOKEN=
# Bearer token required by sirinx-control /api/* (leave empty only for local dev)
CONTROL_API_TOKEN=
# A2A identity for this node (sirinx-control): id, reachable endpoint,
# routing priority; capabilities auto-load from SKILLS_DIR (.claude/skills)
A2A_NODE_ID=
A2A_ENDPOINT=
A2A_PRIORITY=
SKILLS_DIR=
NODE_HEARTBEAT_SHARED_SECRET=

# sirinx-web (Rust) uses this to select the Postgres backend; leave empty
# for the in-memory store. Use the Supabase connection string, e.g.
# postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
REDIS_URL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_IDS=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_COMMANDS=/status,/gates,/sync-plan,/stop
LINE_CHANNEL_SECRET=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AdaptiveSync / PC node placeholders.
# On Mac, point this to a mounted Windows D: share, for example:
# /Volumes/Windows-D/SIRINX_OS/sirinx-co
SIRINX_WINDOWS_D_MOUNT=
SIRINX_SYNC_CONFIRM=

# Telegram sending is disabled unless this is exactly SEND and the command is run with --send.
SIRINX_TELEGRAM_CONFIRM=
