{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sirinx.dev/schemas/agentic-fabric/worker-receipt.v1.schema.json",
  "title": "WorkerReceipt",
  "type": "object",
  "required": ["schema_version", "task_id", "agent_id", "status", "result_ref", "proof_ref", "created_at"],
  "properties": {
    "schema_version": {"const": "agentic-fabric.worker-receipt.v1"},
    "task_id": {"type": "string", "minLength": 3},
    "agent_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["DONE", "BLOCKED", "FAILED", "REPAIR" ]},
    "result_ref": {"type": "string", "format": "uri-reference"},
    "proof_ref": {"type": "string", "format": "uri-reference"},
    "diff_ref": {"type": "string", "format": "uri-reference"},
    "commands": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
