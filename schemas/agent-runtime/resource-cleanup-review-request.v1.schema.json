    "requestId": { "type": "string", "pattern": "^RCRR-[A-Za-z0-9._-]+$", "maxLength": 128 },
    "taskId": { "type": "string", "pattern": "^TASK-[A-Za-z0-9._-]+$", "maxLength": 128 },
